{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/causal-emergence-zoo/benchmark-input.schema.json",
  "title": "causal-emergence-zoo benchmark input specification",
  "description": "Human-authored minimum specification for proposing a new benchmark system before generated expected outputs are attached.",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "conceptual_role",
    "state_labels",
    "tpm",
    "expected_behavior",
    "provenance"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "conceptual_role": { "type": "string" },
    "state_labels": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tpm": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "expected_behavior": {
      "type": "object",
      "required": ["summary"],
      "properties": {
        "summary": { "type": "string" },
        "best_partition": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 }
          }
        },
        "deltaCP_sign": {
          "type": "string",
          "enum": ["positive", "zero", "negative", "unknown"]
        }
      },
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["synthetic", "paper", "empirical", "other"] },
        "generator": { "type": "string" },
        "seed": { "type": ["integer", "null"] },
        "references": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
