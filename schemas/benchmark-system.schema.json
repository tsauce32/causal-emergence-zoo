{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/causal-emergence-zoo/benchmark-system.schema.json",
  "title": "causal-emergence-zoo benchmark system",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "name",
    "description",
    "conceptual_role",
    "state_count",
    "state_labels",
    "microscale",
    "partitions",
    "emergent_hierarchy",
    "provenance"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "id": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "conceptual_role": { "type": "string" },
    "state_count": { "type": "integer", "minimum": 1 },
    "state_labels": {
      "type": "array",
      "items": { "type": "string" }
    },
    "microscale": { "$ref": "#/$defs/scale" },
    "partitions": {
      "type": "array",
      "items": { "$ref": "#/$defs/partition_result" }
    },
    "emergent_hierarchy": {
      "type": "object",
      "required": ["selection_rule", "best_partition", "levels"],
      "properties": {
        "selection_rule": { "type": "string" },
        "best_partition": {
          "type": "object",
          "required": ["partition_id", "blocks", "causal_power", "deltaCP"],
          "properties": {
            "partition_id": { "type": "string" },
            "blocks": { "$ref": "#/$defs/blocks" },
            "causal_power": { "type": "number" },
            "deltaCP": { "type": "number" }
          }
        },
        "levels": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["partition_id", "macro_state_count", "causal_power", "deltaCP"],
            "properties": {
              "partition_id": { "type": "string" },
              "macro_state_count": { "type": "integer", "minimum": 1 },
              "causal_power": { "type": "number" },
              "deltaCP": { "type": "number" }
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["generator", "seed", "precision"],
      "properties": {
        "generator": { "type": "string" },
        "seed": { "type": ["integer", "null"] },
        "precision": { "type": "integer", "minimum": 0 },
        "parameters": { "type": "object" }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "url"],
        "properties": {
          "label": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "matrix": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "integer", "minimum": 0 }
      }
    },
    "metrics": {
      "type": "object",
      "required": [
        "row_entropy_bits",
        "path_entropy_bits",
        "average_effect_entropy_bits",
        "determinism",
        "specificity",
        "degeneracy",
        "effective_information_bits",
        "causal_power"
      ],
      "properties": {
        "row_entropy_bits": { "type": "number" },
        "path_entropy_bits": { "type": "number" },
        "average_effect_entropy_bits": { "type": "number" },
        "determinism": { "type": "number" },
        "specificity": { "type": "number" },
        "degeneracy": { "type": "number" },
        "effective_information_bits": { "type": "number" },
        "causal_power": { "type": "number" }
      }
    },
    "scale": {
      "type": "object",
      "required": ["partition_id", "tpm", "metrics"],
      "properties": {
        "partition_id": { "type": "string" },
        "tpm": { "$ref": "#/$defs/matrix" },
        "metrics": { "$ref": "#/$defs/metrics" }
      }
    },
    "partition_result": {
      "type": "object",
      "required": ["id", "blocks", "macro_state_count", "macro_tpm", "metrics", "deltaCP"],
      "properties": {
        "id": { "type": "string" },
        "blocks": { "$ref": "#/$defs/blocks" },
        "macro_state_count": { "type": "integer", "minimum": 1 },
        "macro_tpm": { "$ref": "#/$defs/matrix" },
        "metrics": { "$ref": "#/$defs/metrics" },
        "deltaCP": { "type": "number" }
      }
    }
  }
}
